# Auto detect text files and normalize line endings to LF
* text=auto

# PHP files
*.php text eol=lf

# JavaScript/React files
*.js text eol=lf
*.jsx text eol=lf

# CSS files
*.css text eol=lf

# JSON files
*.json text eol=lf

# HTML files
*.html text eol=lf

# Markdown files
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# SQL files
*.sql text eol=lf

# 📝 Production .env Template for Hostinger VPS

# Copy this and update the values below, then upload to your VPS

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME="Library Management System"
APP_ENV=production
APP_KEY=base64:Gx//FqJp4jaa2PBT+gVzrKvqRYC5P9orgjpeEuzQKdM=
APP_DEBUG=false
APP_URL=https://delightfulbitsess.com/api

# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=notice

# ============================================
# SQL SERVER DATABASE (Your Current Config)
# ============================================
DB_CONNECTION=sqlsrv
DB_HOST=localhost
DB_PORT=1433
DB_DATABASE=Library_management
DB_USERNAME=SA
DB_PASSWORD=YourStrongPassword123!
DB_ENCRYPT=no
DB_TRUST_SERVER_CERTIFICATE=yes

# ============================================
# BROADCAST & QUEUE
# ============================================
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ============================================
# REDIS (Optional - leave as is)
# ============================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# MAIL (Optional - configure if needed)
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@delightfulbitsess.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_URL=https://delightfulbitsess.com
CORS_ALLOWED_ORIGINS="https://delightfulbitsess.com,https://www.delightfulbitsess.com"

# ============================================
# AWS (Optional - leave empty if not used)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# ============================================
# PUSHER (Optional - leave empty if not used)
# ============================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_REFRESH_TTL=20160

# ============================================
# SANCTUM (API TOKEN AUTHENTICATION)
# ============================================
SANCTUM_STATEFUL_DOMAINS=delightfulbitsess.com,www.delightfulbitsess.com,api.delightfulbitsess.com

# ============================================
# FILE STORAGE
# ============================================
FILESYSTEM_DISK=local
FILESYSTEM_VISIBILITY=private
